NODE_ENV=development
PORT=3001

# PostgreSQL (Prisma requires DATABASE_URL; TypeORM also accepts DB_URL)
DATABASE_URL=postgresql://homegenny_user:root@localhost:5432/homegenny

# false when tables come from homegenny_schema.sql (avoids CREATE vs existing tables)
TYPEORM_SYNCHRONIZE=false

REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:3000,https://homegenny.vercel.app

# Auto-seed portal demo users on startup when missing (enabled by default in production)
AUTO_SEED_USERS=true

# Optional: protect POST /api/v1/health/seed-portal-users for manual re-seed
# SEED_SECRET=your-random-secret
