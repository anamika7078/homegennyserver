# ═══════════════════════════════════════════════
# HomeGenny Backend — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════

# ── App ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v2
APP_NAME=HomeGenny
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ── Database (PostgreSQL) ───────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=homegenny
DB_USER=homegenny_user
DB_PASSWORD=root
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_MIN=2

# ── Redis ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# ── JWT Auth ────────────────────────────────────
JWT_SECRET=CHANGE_ME_MINIMUM_64_CHAR_RANDOM_STRING_HERE_xxxxxxxxxxxxxxxxxxx
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_64_CHAR_RANDOM_STRING_xxxxxxxxxxxxxxxxxxx
JWT_REFRESH_EXPIRY=7d

# ── AWS S3 (Video Certs + Documents) ────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET_DOCUMENTS=homegenny-documents-prod
AWS_S3_BUCKET_VIDEOS=homegenny-videos-prod
AWS_S3_BUCKET_AGREEMENTS=homegenny-agreements-prod
# Signed URL expiry in seconds (15 min)
AWS_S3_SIGNED_URL_EXPIRY=900

# ── WhatsApp (Twilio) ────────────────────────────
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── SMS Fallback (Twilio) ────────────────────────
TWILIO_SMS_FROM=+YOUR_TWILIO_NUMBER

# ── Email (SMTP) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@homegenny.in
SMTP_PASSWORD=YOUR_SMTP_APP_PASSWORD
EMAIL_FROM="HomeGenny <noreply@homegenny.in>"

# ── External Integrations ────────────────────────
# Sarathi (parivahan.gov.in) — requires govt API access
SARATHI_API_URL=https://sarathi.parivahan.gov.in/api
SARATHI_API_KEY=YOUR_SARATHI_API_KEY

# eChallan (echallan.parivahan.gov.in)
ECHALLAN_API_URL=https://echallan.parivahan.gov.in/api
ECHALLAN_API_KEY=YOUR_ECHALLAN_API_KEY

# UIDAI Aadhaar (via licensed TSP)
UIDAI_API_URL=https://api.uidai.gov.in
UIDAI_API_KEY=YOUR_UIDAI_API_KEY
UIDAI_AUA_CODE=YOUR_AUA_CODE
UIDAI_ASA_CODE=YOUR_ASA_CODE

# eSign (Digio)
DIGIO_API_URL=https://api.digio.in/v2
DIGIO_CLIENT_ID=YOUR_DIGIO_CLIENT_ID
DIGIO_CLIENT_SECRET=YOUR_DIGIO_CLIENT_SECRET

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET

# ── Rate Limiting ────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Security ─────────────────────────────────────
BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=10
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_64_CHARS

# ── Monitoring ───────────────────────────────────
SENTRY_DSN=YOUR_SENTRY_DSN
LOG_LEVEL=info

# ── Bull Queue ───────────────────────────────────
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
