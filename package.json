{
  "name": "homegenny-backend",
  "version": "2.0.0",
  "description": "HomeGenny Domestic Staffing Platform — NestJS Backend (Google Cloud Edition)",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:cov": "jest --coverage",
    "migration:run": "typeorm-ts-node-esm -d src/database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-esm -d src/database/data-source.ts migration:revert",
    "migration:show": "typeorm-ts-node-esm -d src/database/data-source.ts migration:show",
    "seed:run": "ts-node src/database/seeds/admin.seed.ts",
    "seed:users": "node scratch/seed_users_now.js",
    "prisma:generate": "prisma generate",
    "prisma:fix": "npx prisma migrate resolve --rolled-back 20260518000000_enterprise_extensions || true; npx prisma migrate resolve --rolled-back 20260528000000_admin_security_triggers || true; npx prisma migrate resolve --rolled-back 20260710112100_add_employee_tables || true",
    "prisma:migrate": "npm run prisma:fix; npx prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:demo": "ts-node scratch/seed_demo_data.ts",
    "prisma:studio": "prisma studio",
    "render:start": "npx prisma migrate resolve --rolled-back 20260518000000_enterprise_extensions || true; npx prisma migrate resolve --rolled-back 20260528000000_admin_security_triggers || true; npx prisma migrate resolve --rolled-back 20260710112100_add_employee_tables || true; npx prisma migrate deploy && node scratch/seed_users_now.js && node dist/main"
  },
  "dependencies": {
    "@google-cloud/logging": "^11.0.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.10.0",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/bull": "^10.0.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "class-variance-authority": "^0.7.0",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "razorpay": "^2.9.2",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/compression": "^1.7.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.15",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
