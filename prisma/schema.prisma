}

model EmployeeCategory {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @unique @db.VarChar(100)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  employees Employee[]

  @@map("employee_categories")
}

model Employee {
  id               String             @id @default(uuid()) @db.Uuid
  employeeId       String             @unique @map("employee_id") @db.VarChar(50)
  fullName         String             @map("full_name") @db.VarChar(200)
  profilePhoto     String?            @map("profile_photo")
  mobile           String             @db.VarChar(20)
  alternateMobile  String?            @map("alternate_mobile") @db.VarChar(20)
  email            String?            @db.VarChar(200)
  dateOfBirth      DateTime           @map("date_of_birth") @db.Date
  gender           String             @db.VarChar(20)
  bloodGroup       String?            @map("blood_group") @db.VarChar(10)
  maritalStatus    String?            @map("marital_status") @db.VarChar(20)
  address          String
  city             String             @db.VarChar(100)
  state            String             @db.VarChar(100)
  pincode          String             @db.VarChar(20)
  emergencyContact Json               @map("emergency_contact")
  joiningDate      DateTime           @map("joining_date") @db.Date
  branchId         String             @map("branch_id") @db.Uuid
  branch           Branch             @relation(fields: [branchId], references: [id])
  department       String             @db.VarChar(100)
  designation      String             @db.VarChar(100)
  categoryId       String             @map("category_id") @db.Uuid
  category         EmployeeCategory   @relation(fields: [categoryId], references: [id])
  reportingManager String?            @map("reporting_manager") @db.VarChar(100)
  employmentType   String             @map("employment_type") @db.VarChar(50)
  salary           Decimal            @db.Decimal(10, 2)
  status           String             @db.VarChar(50)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?          @map("deleted_at") @db.Timestamptz(6)
  documents        EmployeeDocument[]
  attendance       EmployeeAttendance[]

  @@map("employees")
}

model EmployeeDocument {
  id          String    @id @default(uuid()) @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String    @db.VarChar(100)
  docNumber   String?   @map("doc_number") @db.VarChar(100)
  fileUrl     String    @map("file_url")
  issueDate   DateTime? @map("issue_date") @db.Date
  issuedBy    String?   @map("issued_by") @db.VarChar(150)
  validFrom   DateTime? @map("valid_from") @db.Date
  validTill   DateTime? @map("valid_till") @db.Date
  status      String    @db.VarChar(50)
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("employee_documents")
}

model EmployeeAttendance {
  id           String    @id @default(uuid()) @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime  @db.Date
  checkIn      DateTime? @map("check_in") @db.Timestamptz(6)
  checkOut     DateTime? @map("check_out") @db.Timestamptz(6)
  workingHours Decimal?  @map("working_hours") @db.Decimal(4, 2)
  status       String    @db.VarChar(50)
  markedBy     String?   @map("marked_by") @db.Uuid
  approvedBy   String?   @map("approved_by") @db.Uuid
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance")
}
